---
import Default from '@astrojs/starlight/components/SiteTitle.astro';
import versionsConfig from 'virtual:starlight-versions-config';

// Point the site title at the home of the version the reader is browsing
// (e.g. /2.2/) instead of always the site root, so clicking the logo keeps you
// within that version.
const { entry } = Astro.locals.starlightRoute;
const version = versionsConfig.versions.find(
  (v) => entry.id === v.slug || entry.id.startsWith(`${v.slug}/`),
);
if (version) {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  Astro.locals.starlightRoute.siteTitleHref = `${base}/${version.slug}/`;
}
---

<div class="site-title-wrapper sl-flex">
  <Default />
  <a class="built-by" href="https://enix.io" target="_blank" rel="noopener" >
    Built with ♥ by <strong>Enix</strong>
  </a>
</div>

<style>
  .site-title-wrapper {
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }
  .built-by {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    text-decoration: none;
    white-space: nowrap;
    padding-inline-start: 0.75rem;
    border-inline-start: 1px solid var(--sl-color-hairline);
  }
  .built-by:hover {
    color: var(--sl-color-text-accent);
  }
  /* hide the tagline on narrow screens so the header doesn't crowd */
  @media (max-width: 20rem) {
    .built-by {
      display: none;
    }
  }
</style>
